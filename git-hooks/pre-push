#!/bin/bash
# Lightweight git pre-push hook for Bot Army bots
# Keep push fast/reliable: run quick local validation only.

set -e

# Find mix: env override → mise → PATH → fallback
MIX_BIN="${MIX_BIN:-}"
if [ -z "$MIX_BIN" ]; then
  if command -v mise &>/dev/null; then
    MIX_BIN="$(mise which mix 2>/dev/null || true)"
  fi
fi
if [ -z "$MIX_BIN" ]; then
  MIX_BIN="$(command -v mix 2>/dev/null || true)"
fi
if [ -z "$MIX_BIN" ]; then
  MIX_BIN="/Users/abby/.local/share/mise/shims/mix"
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
export HEX_HOME="$REPO_ROOT/.cache/hex"
export MIX_HOME="$REPO_ROOT/.cache/mix"
mkdir -p "$HEX_HOME" "$MIX_HOME"

echo "🔍 Running pre-push checks..."
echo ""
echo "⏱️  This may take 2-5 minutes (compilation + tests)"
echo "⚠️  Do NOT interrupt with --no-verify — hooks are safety gates"
echo ""

push_to_main=0
remote_oid=""
while read -r local_ref local_oid remote_ref remote_oid; do
  if [[ $remote_ref == "refs/heads/main" ]]; then
    push_to_main=1
  fi
done

if [[ $push_to_main -eq 1 ]]; then
  # Skip validation on first push (remote is empty)
  if [[ -z "$remote_oid" ]]; then
    echo "ℹ️  First push to main - skipping validation"
    echo ""
    exit 0
  fi
  echo "⚠️  Pushing to main branch - running fast validation only..."
  echo ""

  echo "📦 Ensuring Hex + dependencies..."
  "$MIX_BIN" local.hex --force || {
    echo "❌ mix local.hex failed - push aborted"
    exit 1
  }
  "$MIX_BIN" deps.get --force || {
    echo "❌ mix deps.get failed - push aborted"
    exit 1
  }
  echo ""

  echo "🔨 Compiling code..."
  "$MIX_BIN" compile --force || {
    echo "❌ Compilation failed - push aborted"
    exit 1
  }

  echo ""
  echo "🧪 Running tests..."
  "$MIX_BIN" test || {
    echo "❌ Tests failed - push aborted"
    exit 1
  }

  echo ""
  echo "✅ Pre-push checks passed"
  echo "ℹ️  Publish releases explicitly with: make push-and-publish"
else
  echo "ℹ️  Pushing to feature branch - skipping pre-push validation"
fi

echo ""
exit 0
